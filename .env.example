# Required secrets — copy to .env and fill in values (never commit .env)

# Secret for POST /api/push (local pusher authentication)
PUSH_SECRET=

# Secret for POST /api/beacon and DELETE /api/instances (instance beacon authentication)
BEACON_SECRET=

# Azure Table Storage connection string (for instance registry)
AZURE_STORAGE_CONNECTION_STRING=

# Comma-separated list of allowed CORS origins
allowed-origins=https://your-app.azurecontainerapps.io

# Local pusher: URL of the agent-monitor backend
PUSH_URL=https://your-app.azurecontainerapps.io/api/push

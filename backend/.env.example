# Agent Monitor Backend Configuration

# ===== HTTP Server =====
PORT=3001
NODE_ENV=development

# ===== Logging =====
# Levels: debug, info, warn, error
LOG_LEVEL=debug

# ===== Authentication Secrets =====
# ⚠️  CHANGE THESE IN PRODUCTION!
# Generate with: openssl rand -base64 32
PUSH_SECRET=oc-push-sk-7f3a9d2e1b8c4f6a
BEACON_SECRET=oc-beacon-sk-change-me-in-prod

# ===== WebSocket Security (Optional) =====
# If set, WebSocket connections require token in query string: ws://host/?token=<value>
# If not set, all WebSocket connections are allowed (backward compatible)
# WS_TOKEN=your-secure-ws-token

# ===== Azure Storage (Optional) =====
# If set, instance beacons are persisted to Azure Table Storage
# If not set, falls back to data/instances.json (local dev)
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...

# ===== Instance Configuration =====
# Time in milliseconds before an instance is marked offline
# Default: 600000 (10 minutes)
OFFLINE_THRESHOLD_MS=600000

# ===== Report Configuration =====
# Base directory where OpenClaw stores final reports and findings
# Default: /home/node/.openclaw/workspace/agents/results
REPORT_BASE_DIR=/home/node/.openclaw/workspace/agents/results
